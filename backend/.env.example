# Umi Backend Configuration
PORT=10201

# --- Hermes Agent (sidecar on port 8642) ---
# HERMES_API_KEY/HERMES_API_URL/HERMES_MODEL configure Hermes' cloud model.
# The backend talks to the local Hermes API server first.
HERMES_API_KEY=
HERMES_API_URL=https://api.fireworks.ai/inference/v1
HERMES_MODEL=accounts/fireworks/routers/kimi-k2p5-turbo
HERMES_PORT=8642
# API_SERVER_KEY=

# --- Fallback: direct LLM if Hermes is not running ---
# LLM_API_KEY=
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- SQLite ---
# DB_PATH=/tmp/umi.db
